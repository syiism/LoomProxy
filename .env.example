# ConfMagr — 环境变量覆盖（同名变量优先级高于 confMagr.py 默认值）

# HTTP 超时
TIMEOUT_CONNECT=5.0
TIMEOUT_POOL=10.0

# 缓存
CACHE_TTL=300
CACHE_MAXSIZE=128

# 服务
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_LOG_LEVEL=info

# 时区偏移（UTC+）
TZ_OFFSET_HOURS=8

# 通用错误码
ERROR_CODE=-1

# 静态数据文件
UTILS_DIRNAME=utils
DATA_DIR_SUFFIX=_data
DATA_FILE_GLOB={source}_*.json
